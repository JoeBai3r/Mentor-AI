# Copy this file to .env (in the same directory as the daemon binary, or the
# directory you run it from) and fill in your key. The daemon loads .env at
# startup; real environment variables always take precedence over this file.

# Required for model-generated recommendations. Without this, the
# recommendation engine falls back to templated suggestions.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-4-6 if unset.
# ANTHROPIC_MODEL=claude-sonnet-4-6
