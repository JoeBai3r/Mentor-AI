{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Activity-monitor",
  "version": "0.1.0",
  "identifier": "com.activitymonitor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{
      "title": "Activity Monitor",
      "width": 1100,
      "height": 740,
      "minWidth": 800,
      "minHeight": 600,
      "decorations": true,
      "transparent": false
    }],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3030 ws://localhost:3030"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/activity-monitor-daemon"]
  }
}
